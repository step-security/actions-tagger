{
  "name": "actionstagger",
  "version": "2.0.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/step-security/actions-tagger.git"
  },
  "main": "./dist/index.js",
  "scripts": {
    "watch": "ncc build src/index.ts --watch",
    "build": "ncc build src/index.ts --license LICENSE --minify --no-cache --out dist",
    "lint": "prettier --check . && tsc && tsc -p ./tests",
    "format": "prettier --write .",
    "test": "jest"
  },
  "engines": {
    "node": ">=24"
  },
  "author": "step-security",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "axios": "1.17.0",
    "semver": "^7.5.4"
  },
  "devDependencies": {
    "@types/jest": "~29.5.8",
    "@types/node": "~20.9.0",
    "@types/semver": "^7.5.5",
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.7.0",
    "prettier": "3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "~5.2.2"
  }
}
